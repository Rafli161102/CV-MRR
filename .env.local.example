# ============================================================================
# Environment Variables - MRR Portfolio
# ============================================================================
# Copy file ini ke .env.local dan isi dengan nilai yang sesuai
# ============================================================================

# ============================================================================
# MongoDB Database
# ============================================================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mrr-portfolio?retryWrites=true&w=majority

# ============================================================================
# NextAuth Authentication
# ============================================================================
NEXTAUTH_SECRET=your-random-secret-key-here-min-32-characters
NEXTAUTH_URL=http://localhost:3000

# ============================================================================
# Admin Credentials (untuk login ke CMS)
# Username plain text, password harus di-hash dengan bcrypt
# Generate hash: https://bcrypt-generator.com/
# ============================================================================
ADMIN_USER=rafli161102
ADMIN_PASSWORD=$2a$10$YourHashedPasswordHere

# ============================================================================
# PWA Configuration
# ============================================================================
NEXT_PUBLIC_APP_NAME=MRR Portfolio
NEXT_PUBLIC_APP_DESCRIPTION="Graphic Designer & Community Development"

# ============================================================================
# Optional: Analytics
# ============================================================================
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# GTM_ID=GTM-XXXXXXX

# ============================================================================
# Optional: External Services
# ============================================================================
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
